# Money Me API - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=Money Me API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=change-this-to-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# XAMPP MySQL (local):
#   Create database 'money_me' in phpMyAdmin first
DATABASE_URL=mysql://root@localhost:3306/money_me
#
# Local development (SQLite — no server needed):
# DATABASE_URL=sqlite+aiosqlite:///./data/money_me.db
#
# Neon PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/money_me?sslmode=require

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5000","http://localhost:8080","http://127.0.0.1:8080"]

# OCR (Windows path — adjust if different)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# External Services (optional)
# OPENAI_API_KEY=
